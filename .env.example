# Proxmox Cloud-Init VM Template Configuration
# Copy this file to .env and adjust values

# VM Memory in MB (default: 512)
VMMEM=512

# VM Network settings
VMSETTINGS="--net0 virtio,bridge=vmbr0"

# Users to create (space-separated)
# Each user needs a corresponding .pub file (e.g., byak.pub)
USERS="byak admin_init orange"

# Cloud-Init default user
CIUSER="admin_init"

# Cloud-Init password (REQUIRED - change this!)
CIPASSWORD="CHANGE_ME_STRONG_PASSWORD"

# Static routes (optional, semicolon-separated)
# Example: ROUTES="192.168.2.0/24 via 192.168.20.5; 10.0.0.0/24 via 10.0.20.1"
ROUTES=""

# Notification URL for ntfy.sh (optional)
# Example: NTFY="https://ntfy.sh/your-private-topic"
NTFY=""
